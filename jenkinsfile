pipeline {
agent any

stages {

    stage('Checkout') {
        steps {
            echo 'Downloading source code'
        }
    }

    stage('Build') {
        steps {
            echo 'Building application'
        }
    }

    stage('Test') {
        steps {
            echo 'Executing tests'
        }
    }

    stage('Deploy') {
        steps {
            echo 'Deploy completed'
        }
    }
}

post {
    success {
        echo 'Pipeline executed successfully'
    }

    failure {
        echo 'Pipeline execution failed'
    }
}

}